---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero2 from '../components/sections/Hero2.astro';
import TrustBadges from '../components/sections/TrustBadges.astro';
import Location from '../components/sections/Location.astro';
import CallToAction from '../components/sections/CallToAction.astro';
import FAQ from '../components/ui/FAQ.astro';
import Footer from '../components/sections/Footer.astro';
import FloatingOffer from '../components/sections/FloatingOffer.astro';
import FloatingSideButtons from '../components/sections/FloatingSideButtons.astro';
import OfferModal from '../components/sections/OfferModal.astro';
import RelatedServices from '../components/sections/RelatedServices.astro';
import OffersGrid from '../components/sections/OffersGrid.astro';
import { parseFaqMarkdown } from '../utils/faqParser.js';

const faqData = await parseFaqMarkdown('commercial.md');

const relatedServices = [
  {
    name: 'Residential Services',
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/%3E%3C/svg%3E',
    link: '#'
  },
  {
    name: 'Specialty Services',
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/%3E%3C/svg%3E',
    link: '#'
  },
  {
    name: 'Emergency Services',
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="white" viewBox="0 0 24 24"%3E%3Cpath d="M13 10V3L4 14h7v7l9-11h-7z"/%3E%3C/svg%3E',
    link: '#'
  },
];

// Use the same service data from Services.astro - Commercial Electrical category
const commercialServiceCards = [
  { 
    name: 'Ground-up Construction', 
    image: 'https://images.unsplash.com/photo-1702128411190-5061e7756d5c?q=80&w=736&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', 
    description: 'Complete electrical infrastructure for new construction projects from foundation to finish.', 
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/%3E%3C/svg%3E', 
    link: '/ground-up-construction',
    detailedDescription: 'Complete electrical infrastructure for new commercial construction projects. From initial design to final installation, we expertly handle all critical aspects of electrical systems for your building.',
    features: [
      'Full electrical system design & planning',
      'Power distribution & panel installation',
      'Code-compliant wiring & conduit systems',
      'Coordination with general contractors'
    ]
  },
  { 
    name: 'Emergency & Standby Power', 
    image: 'https://images.unsplash.com/photo-1715962131558-63e9ef5fb79f?q=80&w=880&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', 
    description: 'Reliable backup power systems to keep your business running during outages.', 
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="black" viewBox="0 0 24 24"%3E%3Cpath d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/%3E%3C/svg%3E',
    detailedDescription: 'Reliable backup power solutions to keep your business running smoothly during outages. Professional generator installation, maintenance, and automatic transfer switch systems.',
    features: [
      'Generator installation & maintenance',
      'Automatic transfer switch systems',
      'Load calculation & sizing',
      'Emergency power testing & certification'
    ]
  },
  { 
    name: 'Commercial HVAC', 
    image: 'https://images.unsplash.com/photo-1770838773181-e1b17ec22fee?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', 
    description: 'Expert electrical services for heating, ventilation, and air conditioning systems.', 
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/%3E%3C/svg%3E',
    detailedDescription: 'Expert electrical services for commercial heating, ventilation, and air conditioning systems. Professional installation and maintenance for optimal performance and energy efficiency.',
    features: [
      'HVAC unit electrical connections',
      'Control system wiring & programming',
      'Energy-efficient system upgrades',
      'Preventive maintenance programs'
    ]
  },
  { 
    name: 'Commercial Panels', 
    image: 'https://images.unsplash.com/photo-1544724569-5f546fd6f2b5?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D', 
    description: 'Professional installation and upgrades for commercial electrical panel systems.', 
    icon: 'data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="black" stroke-width="2"%3E%3Cpath stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/%3E%3C/svg%3E',
    detailedDescription: 'Professional panel upgrades and installations to meet your growing business power demands. Ensure safety and maximum efficiency with modern, reliable electrical distribution systems.',
    features: [
      'Panel upgrades & replacements',
      'Circuit breaker installation',
      'Load balancing & optimization',
      'Safety inspections & code compliance'
    ]
  }
];

const heroData = {
  backgroundImage: "https://images.unsplash.com/photo-1509390144018-eeaf65052242?q=80&w=1074&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  title: "Commercial Electrical Services",
  titleSize: "heading-h2"
};

const serviceDetailData = {
  image: "https://images.unsplash.com/photo-1543333101-840e043d2a7d?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  imageAlt: "Commercial Electrical Services",
  title: "Commercial Electrical",
  description: "We provide comprehensive electrical services for businesses of all sizes, from simple repairs to complex installations. Our experienced team ensures minimal disruption while delivering safe, reliable, code-compliant solutions."
};
---

<Layout 
  title="Commercial Electrical Services" 
>
  <Header />
  
  <Hero2 
    backgroundImage={heroData.backgroundImage}
    title={heroData.title}
    titleSize={heroData.titleSize}
  />

  <TrustBadges />
  
  <!-- Commercial Electrical Overview Section -->
  <section class="bg-white py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Top Section: Image and Text Side by Side -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-4">
        <!-- Left Side: Image -->
        <div class="relative">
          <div class="overflow-hidden shadow-xl rounded-lg">
            <img 
              src={serviceDetailData.image}
              alt={serviceDetailData.imageAlt}
              class="w-full h-[560px] object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <!-- Right Side: Content -->
        <div class="space-y-6">
          <div>
            <p class="text-[#F4C430] font-semibold mb-2 flex items-center gap-2 text-lg tracking-wide">
              <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
              </svg>
              Who We Are
            </p>
            <h2 class="font-bold text-black mb-6 leading-tight" style="font-size: 63px;">
              Commercial Power Solutions
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg mb-6">
              We provide comprehensive electrical services for businesses of all sizes, from simple repairs to complex installations. Our experienced team ensures minimal disruption while delivering reliable solutions that keep your operations running smoothly and efficiently.
            </p>
          </div>

          <!-- Feature Items -->
          <div class="space-y-4">
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 border-2 border-[#F4C430] flex items-center justify-center">
                  <svg class="w-8 h-8 text-[#F4C430]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-xl font-bold text-black mb-2">Complete Infrastructure</h3>
                <p class="text-gray-600 leading-relaxed">
                  Full electrical system design, installation, and maintenance for commercial buildings and facilities.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 border-2 border-[#F4C430] flex items-center justify-center">
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
                  </svg>
                </div>
              </div>
              <div>
                <h3 class="text-xl font-bold text-black mb-2">24/7 Emergency Service</h3>
                <p class="text-gray-600 leading-relaxed">
                  Reliable backup power systems and emergency electrical services to keep your business running.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .animate-spin-slow {
      animation: spin 8s linear infinite;
    }
    
    @keyframes spin {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }
  </style>

  <!-- Commercial Electrical Services Grid -->
  <section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="mb-8 text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
          </svg>
          <p class="text-[#F4C430] font-semibold text-lg">Our Services</p>
        </div>
        <h2 class="heading-h2 font-bold text-black mb-4">Commercial Electrical Services</h2>
        <p class="text-gray-700 leading-relaxed max-w-5xl mx-auto text-[17px]">
          Professional electrical solutions for businesses, from simple installations to complex systems.
        </p>
      </div>

      <!-- Services Grid - 4 Cards in 1 Row -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        {commercialServiceCards.map((service, index) => (
          <div 
            class={`opacity-0 translate-y-[30px] ${
              index === 0 ? 'animate-[fadeInUp_0.8s_ease-out_0.1s_forwards]' :
              index === 1 ? 'animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]' :
              index === 2 ? 'animate-[fadeInUp_0.8s_ease-out_0.3s_forwards]' :
              'animate-[fadeInUp_0.8s_ease-out_0.4s_forwards]'
            }`}
          >
            <a 
              href={service.link || '#'}
              class="group cursor-pointer relative overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-shadow duration-500 block"
            >
              <!-- Image (keeps square aspect ratio) -->
              <div class="w-full aspect-square overflow-hidden bg-gray-200">
                <img 
                  src={service.image} 
                  alt={service.name}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              
              <!-- Default Bottom Label (Always visible) -->
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-[#F4C430] via-[#F4C430]/95 to-[#F4C430]/80 py-4 px-4 flex items-center gap-2 z-10 transition-all duration-300 group-hover:opacity-0 group-hover:translate-y-2">
                <div class="w-5 h-5 flex-shrink-0" set:html={service.icon.replace('data:image/svg+xml,', '').replace(/%3C/g, '<').replace(/%3E/g, '>').replace(/%22/g, '"').replace(/%20/g, ' ').replace(/%3D/g, '=').replace(/%2F/g, '/')} />
                <h4 class="font-black text-black text-[16px] leading-tight">{service.name}</h4>
              </div>
              
              <!-- Hover Overlay - Slides from bottom to top with enhanced effects -->
              <div class="absolute inset-0 bg-gradient-to-t from-[#F4C430] via-[#F4C430]/95 to-[#F4C430]/80 translate-y-full group-hover:translate-y-0 transition-all duration-700 ease-out flex flex-col items-start justify-center px-8 z-20">
                <!-- Decorative line -->
                <div class="w-16 h-1 bg-black mb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-300"></div>
                
                <h4 class="font-black text-black text-left text-[20px] mb-4 leading-tight opacity-0 group-hover:opacity-100 transition-all duration-500 delay-200 transform translate-y-4 group-hover:translate-y-0">{service.name}</h4>
                
                <p class="text-black text-left text-[15px] font-semibold leading-relaxed opacity-0 group-hover:opacity-100 transition-all duration-500 delay-300 transform translate-y-4 group-hover:translate-y-0">{service.description}</p>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <OffersGrid />
  <RelatedServices services={relatedServices} />
  <FAQ faqData={faqData} />
  <CallToAction />
  <Location />
  <Footer />
  <FloatingOffer />
  <FloatingSideButtons showOnScroll={true} triggerSection="why-choose-us" />
  <OfferModal />
</Layout>
