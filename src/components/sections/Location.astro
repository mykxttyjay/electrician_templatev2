---
const locations = [
  {
    id: 'santa-monica',
    name: 'Santa Monica',
    pageUrl: '/santa-monica',
    isActive: false
  },
  {
    id: 'pasadena',
    name: 'Pasadena',
    pageUrl: '/location',
    isActive: false
  },
  {
    id: 'glendale',
    name: 'Glendale',
    pageUrl: '/location',
    isActive: false
  },
  {
    id: 'beverly-hills',
    name: 'Beverly Hills',
    pageUrl: '/location',
    isActive: false
  }
];

// Los Angeles County wide map
const losAngelesMapUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d423286.27404345275!2d-118.69191843026566!3d34.02016130653294!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80c2c75ddc27da13%3A0xe22fdf6f254608f4!2sLos%20Angeles%20County%2C%20CA!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus';
---

<section class="relative bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-10 location-header">
      <div class="flex items-center justify-center gap-2 mb-1">
        <svg class="w-6 h-6 text-[#B8860B]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
        </svg>
        <p class="text-[#B8860B] font-semibold text-[18px] tracking-wider">Our Location</p>
      </div>
      <h2 class="heading-h2 font-bold text-black mb-4">Service Areas in Los Angeles</h2>
      <p class="text-gray-700 text-xl max-w-4xl mx-auto">
        Expert electrical services across multiple locations with 24/7 emergency support
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Left Column: Location Tabs & Description -->
      <div class="lg:col-span-1 space-y-6">
        <!-- Location Tabs -->
        <div class="bg-black p-6 shadow-lg rounded-lg location-tabs">
          <h3 class="text-[31px] font-bold text-white mb-4">
            Select Location
          </h3>
          <div class="space-y-3">
            {locations.map((location) => (
              <a
                href={location.pageUrl}
                class={`location-tab w-full px-5 py-4 ${location.isActive ? 'bg-[#F4C430]' : 'bg-[#2a2a2a]'} border-2 border-transparent font-semibold transition-all hover:bg-[#F4C430] flex items-center justify-between group`}
                data-location-id={location.id}
              >
                <span class="flex items-center gap-3">
                  <svg class={`w-5 h-5 ${location.isActive ? 'text-black' : 'text-gray-400'} group-hover:text-black transition-colors`} fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                  </svg>
                  <span class={`text-left ${location.isActive ? 'text-black' : 'text-white'} group-hover:text-black`}>{location.name}</span>
                </span>
                <svg class={`w-5 h-5 ${location.isActive ? 'text-black' : 'text-gray-400'} group-hover:text-black transition-colors`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>



        <!-- Contact CTA -->
        <div class="bg-black text-white p-6 shadow-lg rounded-lg location-cta">
          <h3 class="text-[31px] font-bold mb-2">Need Service Now?</h3>
          <p class="text-gray-300 text-[16px] mb-4">Call us for immediate assistance</p>
          <a href="tel:+2345678912" class="flex items-center justify-center gap-3 bg-[#F4C430] text-black font-bold py-3 px-6 hover:bg-[#e5b52a] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
            </svg>
            +(234) 567 8912
          </a>
        </div>
      </div>

      <!-- Right Column: Map -->
      <div class="lg:col-span-2">
        <div class="relative bg-gradient-to-br from-gray-100 to-gray-200 overflow-hidden shadow-2xl location-map h-full min-h-[500px] lg:min-h-[600px] rounded-lg">
          <!-- Map iframe -->
          <iframe 
            id="location-map"
            src={losAngelesMapUrl}
            width="100%"
            height="100%"
            class=""
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Google Maps showing Los Angeles County service area"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>



<style>
  .location-header {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .location-tabs {
    opacity: 0;
    transform: translateX(-20px);
  }

  .location-tabs.animate {
    animation: slideInLeft 0.8s ease-out 0.3s forwards;
  }

  .location-description {
    opacity: 0;
    transform: translateX(-20px);
  }

  .location-description.animate {
    animation: slideInLeft 0.8s ease-out 0.4s forwards;
  }

  .location-cta {
    opacity: 0;
    transform: translateX(-20px);
  }

  .location-cta.animate {
    animation: slideInLeft 0.8s ease-out 0.5s forwards;
  }

  .location-map {
    opacity: 0;
    transform: translateX(20px);
  }

  .location-map.animate {
    animation: slideInRight 0.8s ease-out 0.4s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInRight {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const locationObserverOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const locationObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        locationObserver.unobserve(entry.target);
      }
    });
  }, locationObserverOptions);

  // Observe location elements
  const locationTabs = document.querySelector('.location-tabs');
  const locationDescription = document.querySelector('.location-description');
  const locationCta = document.querySelector('.location-cta');
  const locationMap = document.querySelector('.location-map');
  
  if (locationTabs) locationObserver.observe(locationTabs);
  if (locationDescription) locationObserver.observe(locationDescription);
  if (locationCta) locationObserver.observe(locationCta);
  if (locationMap) locationObserver.observe(locationMap);
</script>
