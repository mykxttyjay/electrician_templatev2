---
// Import all testimonial markdown files
const testimonialFiles = import.meta.glob('../content/testimonials/testimonial-*.md', { eager: true });
const testimonials = Object.values(testimonialFiles).map((file: any) => {
  const rawContent = file.rawContent ? file.rawContent() : '';
  const cleanText = rawContent.replace(/^---[\s\S]*?---\n/, '').trim(); 
  
  return {
    name: file.frontmatter.name,
    role: file.frontmatter.role,
    image: file.frontmatter.image,
    text: cleanText
  };
});

// Reusable SVG paths
const starPath = "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z";
const quotePath = "M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z";
const lightningPath = "M13 2L3 14h8l-1 8 10-12h-8l1-8z";
const checkmarkPath = "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z";

const googlePaths = {
  blue: "M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z",
  green: "M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z",
  yellow: "M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z",
  red: "M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
};
---

<section class="relative bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Section Header -->
    <div class="mb-8 testimonials-header">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <!-- Left Side: Title and Description -->
        <div class="md:max-w-3xl">
          <p class="text-[#B8860B] font-semibold text-lg flex items-center gap-2">
            <svg class="w-5 h-5 text-[#B8860B]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
            </svg>
            Testimonials
          </p>
          <h2 class="heading-h2 font-bold text-black mb-3">What Our Clients Say</h2>
          <p class="text-gray-700 leading-relaxed text-subtitle">
            Hear from our satisfied customers about their experience with our professional electrical services and dedicated team.
          </p>
        </div>

        <!-- Right Side: Google Rating Badge -->
        <div class="flex-shrink-0 md:max-w-3xl">
          <div class="flex items-center gap-4">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                <span class="text-gray-600 font-medium text-lg">Google Rating</span>
              </div>
              <div class="flex items-center gap-3 mb-2">
                <span class="font-bold text-black" style="font-size: 60px; line-height: 1;">5.0</span>
                <div class="flex gap-1">
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  <svg class="w-8 h-8 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
              </div>
              <p class="text-gray-500 text-base">200 reviews</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Carousel Container -->
    <div class="relative testimonials-carousel -mx-4 sm:-mx-6 lg:-mx-8">
      <div class="testimonial-carousel overflow-hidden px-4 sm:px-6 lg:px-8">
        <div class="testimonial-track flex transition-transform duration-500 ease-in-out -mx-4">
          {testimonials.map((testimonial) => (
          <div class="testimonial-slide min-w-full md:min-w-[33.333%] px-4">
            <div class="relative pt-12">
              <div class="absolute top-0 left-8 z-10">
                <img 
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg"
                />
              </div>
              
              <div class="bg-white rounded-2xl p-6 pt-14 relative">
                <div class="absolute top-2 right-6">
                  <svg class="w-16 h-16 text-gray-300 opacity-70" fill="currentColor" viewBox="0 0 24 24">
                    <path d={quotePath}/>
                  </svg>
                </div>
                
                <div class="mb-3">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="text-lg font-bold text-black">{testimonial.name}</h3>
                    <svg class="w-5 h-5 text-[#1DA1F2] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="flex gap-1">
                    {[...Array(5)].map(() => (
                      <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                        <path d={starPath}/>
                      </svg>
                    ))}
                  </div>
                </div>
                
                <p class="text-gray-600 leading-relaxed text-base mb-3">
                  "{testimonial.text}"
                </p>
                
                <div class="flex items-center gap-1.5 text-gray-500" style="font-size: 12.5px;">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
                    <path d={googlePaths.blue} fill="#4285F4"/>
                    <path d={googlePaths.green} fill="#34A853"/>
                    <path d={googlePaths.yellow} fill="#FBBC05"/>
                    <path d={googlePaths.red} fill="#EA4335"/>
                  </svg>
                  <span class="font-medium">Posted on Google</span>
                </div>
                
                <div class="absolute -bottom-3 left-12 w-6 h-6 bg-white transform rotate-45"></div>
              </div>
            </div>
          </div>
          ))}
          {testimonials.map((testimonial) => (
          <div class="testimonial-slide min-w-full md:min-w-[33.333%] px-4">
            <div class="relative pt-12">
              <div class="absolute top-0 left-8 z-10">
                <img 
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg"
                />
              </div>
              
              <div class="bg-white rounded-2xl p-6 pt-14 relative">
                <div class="absolute top-2 right-6">
                  <svg class="w-16 h-16 text-gray-300 opacity-70" fill="currentColor" viewBox="0 0 24 24">
                    <path d={quotePath}/>
                  </svg>
                </div>
                
                <div class="mb-3">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="text-lg font-bold text-black">{testimonial.name}</h3>
                    <svg class="w-5 h-5 text-[#1DA1F2] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div class="flex gap-1">
                    {[...Array(5)].map(() => (
                      <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
                        <path d={starPath}/>
                      </svg>
                    ))}
                  </div>
                </div>
                
                <p class="text-gray-600 leading-relaxed text-base mb-3">
                  "{testimonial.text}"
                </p>
                
                <div class="flex items-center gap-1.5 text-gray-500" style="font-size: 12.5px;">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
                    <path d={googlePaths.blue} fill="#4285F4"/>
                    <path d={googlePaths.green} fill="#34A853"/>
                    <path d={googlePaths.yellow} fill="#FBBC05"/>
                    <path d={googlePaths.red} fill="#EA4335"/>
                  </svg>
                  <span class="font-medium">Posted on Google</span>
                </div>
                
                <div class="absolute -bottom-3 left-12 w-6 h-6 bg-white transform rotate-45"></div>
              </div>
            </div>
          </div>
          ))}
        </div>
      </div>

      <!-- Dots Navigation with Trustindex Badge -->
      <div class="relative flex justify-center mt-12 gap-2 px-4 sm:px-6 lg:px-8">
        {testimonials.map((_, index) => (
        <button 
          class="carousel-dot h-1 w-12 transition-all duration-300"
          data-index={index}
          aria-label={`Go to testimonial ${index + 1}`}
        >
          <span class={`block w-full h-full ${index === 0 ? 'bg-[#F4C430]' : 'bg-gray-300'}`}></span>
        </button>
        ))}

        <!-- Trustindex Verification Badge - Absolute positioned to the right -->
        <div class="absolute right-4 sm:right-6 lg:right-8 top-1/2 -translate-y-1/2 trustindex-badge">
          <a 
            href="https://www.trustindex.io/" 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 bg-[#2D7A4F] hover:bg-[#246239] text-white px-3 py-1.5 rounded transition-colors duration-300"
            style="font-size: 13px;"
          >
            <span class="font-medium">Verified by Trustindex</span>
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" fill="white" opacity="0.3"/>
              <path d={checkmarkPath} fill="white"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-header {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .testimonials-carousel {
    opacity: 0;
    transform: translateY(30px);
  }

  .testimonials-carousel.animate {
    animation: fadeInUp 0.8s ease-out 0.3s forwards;
  }

  .trustindex-badge {
    opacity: 0;
    transform: translateY(20px);
  }

  .trustindex-badge.animate {
    animation: fadeInUp 0.8s ease-out 0.5s forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const testimonialsObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const testimonialsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        testimonialsObserver.unobserve(entry.target);
      }
    });
  }, testimonialsObserverOptions);

  // Observe testimonials elements
  const testimonialsCarousel = document.querySelector('.testimonials-carousel');
  const trustindexBadge = document.querySelector('.trustindex-badge');
  
  if (testimonialsCarousel) testimonialsObserver.observe(testimonialsCarousel);
  if (trustindexBadge) testimonialsObserver.observe(trustindexBadge);

  // Carousel functionality
  let currentIndex = 0;
  const track = document.querySelector('.testimonial-track') as HTMLElement;
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  
  // Determine slides per view based on screen size
  function getSlidesPerView() {
    return window.innerWidth >= 768 ? 3 : 1;
  }
  
  const totalSlides = slides.length / 2; // Actual number of unique slides
  
  function updateCarousel(smooth = true) {
    const slidesPerView = getSlidesPerView();
    const offset = -(currentIndex * (100 / slidesPerView));
    
    if (smooth) {
      track.style.transition = 'transform 500ms ease-in-out';
    } else {
      track.style.transition = 'none';
    }
    
    track.style.transform = `translateX(${offset}%)`;
    
    // Update dots
    const dotIndex = currentIndex % totalSlides;
    dots.forEach((dot, index) => {
      const dotSpan = dot.querySelector('span');
      if (dotSpan) {
        if (index === dotIndex) {
          dotSpan.classList.remove('bg-gray-300');
          dotSpan.classList.add('bg-[#F4C430]');
        } else {
          dotSpan.classList.remove('bg-[#F4C430]');
          dotSpan.classList.add('bg-gray-300');
        }
      }
    });
  }
  
  function nextSlide() {
    currentIndex++;
    updateCarousel(true);
    
    // Reset to beginning when reaching duplicates
    if (currentIndex >= totalSlides) {
      setTimeout(() => {
        currentIndex = 0;
        updateCarousel(false);
      }, 500);
    }
  }
  
  // Dot navigation
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel(true);
    });
  });
  
  // Auto-play carousel
  let autoplayInterval = setInterval(nextSlide, 5000);
  
  // Pause on hover
  const carousel = document.querySelector('.testimonial-carousel');
  carousel?.addEventListener('mouseenter', () => {
    clearInterval(autoplayInterval);
  });
  
  carousel?.addEventListener('mouseleave', () => {
    autoplayInterval = setInterval(nextSlide, 5000);
  });
  
  // Handle window resize
  window.addEventListener('resize', () => updateCarousel(true));
  
  // Initial update
  updateCarousel(false);
</script>
