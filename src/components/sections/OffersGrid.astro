---
---

<section class="bg-[#F8F8F8] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
      <!-- Maintenance Plan Card (Left - Smaller) -->
      <a href="/maintenance" class="block group md:scale-95">
        <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 h-[500px] border-2 border-dashed border-gray-300 hover:border-[#F4C430] group-hover:scale-105">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1615774925655-a0e97fc85c14?q=80&w=735&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Maintenance" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/70 to-black/50"></div>
          </div>
          
          <!-- Badge -->
          <div class="absolute top-4 right-4 bg-[#F4C430] text-black px-3 py-1 rounded-full text-xs font-bold z-10">
            BEST VALUE
          </div>

          <div class="p-6 relative z-10 h-full flex flex-col justify-end">
            <!-- Icon -->
            <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>

            <h3 class="text-3xl font-black text-white mb-2">MAINTENANCE PLAN</h3>
            
            <div class="mb-6">
              <p class="text-gray-300 text-sm mb-4">FOR AS LOW AS</p>
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-[#F4C430]">$14.33</span>
                <span class="text-white text-lg font-semibold">PER MONTH</span>
              </div>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Priority scheduling</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Annual safety inspections</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>15% off all repairs</span>
              </li>
            </ul>

            <!-- Arrow indicator -->
            <div class="mt-6 flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Financing Card (Center - Larger) -->
      <a href="/financing" class="block group md:scale-110">
        <div class="relative bg-gradient-to-br from-white via-gray-50 to-white rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 h-full border-2 border-dashed border-gray-300 hover:border-[#F4C430] group-hover:scale-105">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1555009784-ae7e7d1b97aa?q=80&w=627&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Financing" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
          </div>
          
          <!-- Badge -->
          <div class="absolute top-4 right-4 bg-[#F4C430] text-black px-3 py-1 rounded-full text-xs font-bold z-10">
            FLEXIBLE
          </div>

          <div class="p-8 relative z-10 h-full flex flex-col justify-end">
            <!-- Icon -->
            <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
              </svg>
            </div>

            <h3 class="text-3xl font-black text-white mb-2">NO INTEREST NO PAYMENT</h3>
            
            <div class="mb-6">
              <p class="text-gray-300 text-sm mb-2">UNTIL 2026</p>
              <p class="text-white text-lg font-semibold">WITH APPROVED FINANCING</p>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Quick approval process</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Flexible payment plans</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>No hidden fees</span>
              </li>
            </ul>

            <!-- Arrow indicator -->
            <div class="mt-6 flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Coupons Card (Right - Smaller) -->
      <a href="/specials" class="block group md:scale-95">
        <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 h-[500px] border-2 border-dashed border-gray-300 hover:border-[#F4C430] group-hover:scale-105">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1758101755915-462eddc23f57?q=80&w=1074&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Special Offers" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-red-900/95 via-red-900/80 to-black/70"></div>
          </div>
          
          <!-- Badge -->
          <div class="absolute top-4 right-4 bg-[#F4C430] text-black px-3 py-1 rounded-full text-xs font-bold z-10">
            LIMITED TIME
          </div>

          <div class="p-6 relative z-10 h-full flex flex-col justify-end">
            <!-- Icon -->
            <div class="w-16 h-16 bg-[#F4C430] rounded-full flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-black" fill="currentColor" viewBox="0 0 24 24">
                <path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
              </svg>
            </div>

            <h3 class="text-3xl font-black text-white mb-2">20% OFF</h3>
            
            <div class="mb-6">
              <p class="text-gray-300 text-sm mb-4">ALL EMERGENCY</p>
              <p class="text-white text-lg font-semibold">ELECTRICAL SERVICES</p>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>24/7 emergency service</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Same-day service available</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Valid for new customers</span>
              </li>
            </ul>

            <!-- Arrow indicator -->
            <div class="mt-6 flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
