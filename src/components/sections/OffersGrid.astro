---
---

<section class="relative bg-gray-100 py-20 px-4 sm:px-6 lg:px-8 offers-section-bg">
  
  <!-- Content -->
  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center">
      <!-- Maintenance Plan Card (Left - Smaller) -->
      <a href="/#maintenance-plan" class="block group w-[430px] mx-auto">
        <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 h-[530px] border-2 border-dashed border-[#F4C430] hover:border-[#F4C430] group-hover:scale-105 overflow-hidden">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1615774925655-a0e97fc85c14?q=80&w=735&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Maintenance" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/70 to-black/50"></div>
          </div>
          
          <!-- Diagonal Ribbon Banner -->
          <div class="absolute top-8 -right-12 w-48 transform rotate-45 z-20 shadow-lg bg-[#F4C430]">
            <p class="text-center py-2 font-black uppercase tracking-wider text-xs text-black">
              MAINTENANCE
            </p>
          </div>

          <div class="p-6 relative z-10 h-full flex flex-col justify-between">
            <div></div>
            <div>
            <h3 class="text-3xl font-black text-white mb-2">MAINTENANCE</h3>
            
            <div class="mb-6">
              <p class="text-white text-[14px] mb-4">PROTECT YOUR HOME FOR AS LOW AS</p>
              <div class="flex items-baseline gap-2">
                <span class="text-5xl font-black text-[#F4C430]">$14.33</span>
                <span class="text-white text-lg font-semibold">PER MONTH</span>
              </div>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Priority emergency scheduling</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Comprehensive annual safety inspections</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>15% discount on all repairs & upgrades</span>
              </li>
            </ul>
            </div>

            <!-- Arrow indicator -->
            <div class="flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Financing Card (Center - Larger) -->
      <a href="/financing" class="block group w-[430px] mx-auto">
        <div class="relative bg-gradient-to-br from-white via-gray-50 to-white rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 h-[570px] border-2 border-dashed border-[#F4C430] hover:border-[#F4C430] group-hover:scale-105 overflow-hidden">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1555009784-ae7e7d1b97aa?q=80&w=627&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Financing" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
          </div>
          
          <!-- Diagonal Ribbon Banner -->
          <div class="absolute top-8 -right-12 w-48 transform rotate-45 z-20 shadow-lg bg-[#F4C430]">
            <p class="text-center py-2 font-black uppercase tracking-wider text-xs text-black">
              FINANCING
            </p>
          </div>

          <div class="p-8 relative z-10 h-full flex flex-col justify-between">
            <div></div>
            <div>
            <h3 class="text-[50px] font-black text-white mb-2 leading-tight">NO INTEREST NO PAYMENT</h3>
            
            <div class="mb-6">
              <p class="text-white text-[14px] mb-2">UNTIL 2026</p>
              <p class="text-white text-lg font-semibold">WITH APPROVED FINANCING</p>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Fast & easy approval process</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Multiple flexible payment options</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Zero hidden fees or surprises</span>
              </li>
            </ul>
            </div>

            <!-- Arrow indicator -->
            <div class="flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Coupons Card (Right - Smaller) -->
      <a href="/specials" class="block group w-[430px] mx-auto">
        <div class="relative bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 h-[530px] border-2 border-dashed border-[#F4C430] hover:border-[#F4C430] group-hover:scale-105 overflow-hidden">
          <!-- Background Image -->
          <div class="absolute inset-0">
            <img 
              src="https://images.unsplash.com/photo-1758101755915-462eddc23f57?q=80&w=1074&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
              alt="Special Offers" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/80 to-black/60"></div>
          </div>
          
          <!-- Diagonal Ribbon Banner -->
          <div class="absolute top-8 -right-12 w-48 transform rotate-45 z-20 shadow-lg bg-[#F4C430]">
            <p class="text-center py-2 font-black uppercase tracking-wider text-xs text-black">
              LIMITED TIME
            </p>
          </div>

          <div class="p-6 relative z-10 h-full flex flex-col justify-between">
            <div></div>
            <div>
            <h3 class="text-[80px] font-black text-[#F4C430] mb-2 leading-tight">20% OFF</h3>
            
            <div class="mb-6">
              <p class="text-white text-[14px] mb-4">ALL EMERGENCY</p>
              <p class="text-white text-lg font-semibold">ELECTRICAL SERVICES</p>
            </div>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>24/7 rapid emergency response</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>Same-day service guaranteed</span>
              </li>
              <li class="flex items-center gap-3 text-white">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span>New customers only - limited time</span>
              </li>
            </ul>
            </div>

            <!-- Arrow indicator -->
            <div class="flex items-center justify-end text-[#F4C430] font-bold group-hover:translate-x-2 transition-transform">
              <span class="mr-2">Learn More</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>


<style>
  .offers-section-bg {
    overflow: hidden;
  }
  
  .offers-section-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/lightbulb-pattern.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    opacity: 0.1;
    z-index: 0;
    pointer-events: none;
  }
</style>
