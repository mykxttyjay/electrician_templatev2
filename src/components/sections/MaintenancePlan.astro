---
import Button from '../ui/Button.astro';

const plans = [
  {
    name: 'Basic Plan',
    price: '$99',
    period: 'per year',
    featured: false,
    bgColor: 'bg-[#F8F8F8]',
    textColor: 'text-black',
    priceColor: 'text-[#F4C430]',
    borderColor: 'border-gray-300 hover:border-[#F4C430]',
    buttonVariant: 'coupon' as const,
    features: [
      'Annual electrical inspection',
      'Priority scheduling',
      '10% discount on repairs',
      'Safety report included'
    ]
  },
  {
    name: 'Premium Plan',
    price: '$199',
    period: 'per year',
    featured: true,
    bgColor: 'bg-[#1a1a1a]',
    textColor: 'text-white',
    priceColor: 'text-[#F4C430]',
    borderColor: 'border-[#F4C430]',
    buttonVariant: 'couponWhite' as const,
    features: [
      'Bi-annual inspections',
      '24/7 priority service',
      '20% discount on repairs',
      'Free emergency callouts',
      'Extended warranty coverage'
    ]
  },
  {
    name: 'Professional Plan',
    price: '$349',
    period: 'per year',
    featured: false,
    bgColor: 'bg-[#F8F8F8]',
    textColor: 'text-black',
    priceColor: 'text-[#F4C430]',
    borderColor: 'border-gray-300 hover:border-[#F4C430]',
    buttonVariant: 'coupon' as const,
    features: [
      'Quarterly inspections',
      'VIP priority service',
      '30% discount on repairs',
      'Unlimited emergency calls',
      'Dedicated account manager',
      'Premium warranty coverage'
    ]
  }
];
---

<section class="bg-white pt-20 pb-28 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="mb-8 text-center opacity-0 animate-[fadeInUp_0.8s_ease-out_forwards]">
      <div class="flex items-center justify-center gap-2">
        <svg class="w-5 h-5 text-[#F4C430]" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
        </svg>
        <p class="text-[#F4C430] font-semibold text-lg">Maintenance Plan</p>
      </div>
      <h2 class="heading-h2 font-bold text-black mb-2">Protect Your Investment</h2>
      <p class="text-gray-700 leading-relaxed max-w-3xl mx-auto text-subtitle">
        Keep your electrical systems running smoothly with our comprehensive maintenance plans
      </p>
    </div>

    <!-- Plans Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {plans.map((plan, index) => (
        <div 
          class={`${plan.bgColor} p-8 rounded-lg border-2 ${plan.borderColor} ${plan.featured ? 'border-4 relative transform md:scale-105' : ''} transition-all duration-300 flex flex-col opacity-0 translate-y-[30px] ${
            index === 0 ? 'animate-[fadeInUp_0.8s_ease-out_0.2s_forwards]' :
            index === 1 ? 'animate-[fadeInUp_0.8s_ease-out_0.4s_forwards]' :
            'animate-[fadeInUp_0.8s_ease-out_0.6s_forwards]'
          }`}
        >
          {plan.featured && (
            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-[#F4C430] text-black px-6 py-1 font-bold text-sm">
              MOST POPULAR
            </div>
          )}
          <div class="text-center mb-6">
            <h3 class={`text-2xl font-bold ${plan.textColor} mb-2`}>{plan.name}</h3>
            <div class={`text-4xl font-black ${plan.priceColor} mb-2`}>{plan.price}</div>
            <p class={plan.featured ? 'text-gray-300' : 'text-gray-600'}>{plan.period}</p>
          </div>
          <ul class="space-y-3 mb-8 flex-grow">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg class="w-5 h-5 text-[#F4C430] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
                <span class={plan.textColor}>{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-auto">
            <Button 
              variant={plan.buttonVariant}
              size="md"
              href="/contact"
              class="w-full py-3"
            >
              Get Started
            </Button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
