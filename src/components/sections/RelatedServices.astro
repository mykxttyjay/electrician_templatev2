---
interface Service {
  name: string;
  icon: string;
  link: string;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

// Function to extract path data from data URI
function extractPathFromDataUri(dataUri: string): string {
  try {
    // Decode the data URI
    const svgString = decodeURIComponent(dataUri.replace('data:image/svg+xml,', ''));
    // Extract the d attribute from path
    const pathMatch = svgString.match(/d="([^"]+)"/);
    return pathMatch ? pathMatch[1] : '';
  } catch {
    return '';
  }
}
---

<section class="bg-[#1a1a1a] py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12 related-services-header opacity-0">
      <h2 class="heading-h2 font-bold text-white">Related Electrical Services</h2>
    </div>

    <!-- Services Grid -->
    <div class="flex justify-center">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 related-services-grid opacity-0">
      {services.map((service, index) => (
        <a 
          href={service.link}
          class="group border-2 border-gray-300 bg-white rounded-lg p-8 hover:border-[#F4C430] hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 flex flex-col items-center text-center"
          data-service-index={index}
        >
          <!-- Icon Circle with Rotating Dashed Border -->
          <div class="relative w-20 h-20 mb-6">
            <!-- Dashed circle border with rotation animation -->
            <div class="absolute inset-0 rounded-full border-4 border-dashed border-[#F4C430] opacity-30 group-hover:opacity-50 transition-opacity animate-spin-slow"></div>
            <!-- Inner solid circle with icon -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-12 h-12 bg-[#F4C430] group-hover:bg-black rounded-full flex items-center justify-center transition-colors">
                <svg class="w-6 h-6 text-black group-hover:text-[#F4C430] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={extractPathFromDataUri(service.icon)}></path>
                </svg>
              </div>
            </div>
          </div>
          
          <!-- Service Name -->
          <h3 class="text-xl font-bold text-black group-hover:text-[#F4C430] transition-colors duration-300">
            {service.name}
          </h3>
        </a>
      ))}
      </div>
    </div>
  </div>
</section>

<style>
  .related-services-header {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .related-services-grid {
    opacity: 0;
  }

  .related-services-grid.animate {
    opacity: 1;
  }

  .related-services-grid > a {
    opacity: 0;
    transform: translateY(30px);
  }

  .related-services-grid.animate > a {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .related-services-grid.animate > a[data-service-index="0"] {
    animation-delay: 0.1s;
  }

  .related-services-grid.animate > a[data-service-index="1"] {
    animation-delay: 0.2s;
  }

  .related-services-grid.animate > a[data-service-index="2"] {
    animation-delay: 0.3s;
  }

  .related-services-grid.animate > a[data-service-index="3"] {
    animation-delay: 0.4s;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin-slow {
    animation: spin-slow 8s linear infinite;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const relatedServicesObserverOptions = {
    threshold: 0.2,
    rootMargin: '0px 0px -50px 0px'
  };

  const relatedServicesObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate');
        relatedServicesObserver.unobserve(entry.target);
      }
    });
  }, relatedServicesObserverOptions);

  // Observe elements
  const grid = document.querySelector('.related-services-grid');
  
  if (grid) relatedServicesObserver.observe(grid);
</script>
