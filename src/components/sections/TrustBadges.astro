---
---

<section class="bg-white py-12 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <!-- Carousel Container with Gradients -->
    <div class="relative">
      <!-- Left Gradient -->
      <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      
      <!-- Right Gradient -->
      <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>
      
      <!-- Scrolling Track -->
      <div class="overflow-hidden">
        <div class="trust-badges-track flex items-center gap-32 animate-scroll">
          <!-- First Set of Badges -->
          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/24-7-service.png" 
              alt="24/7 Service Available" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/angi-certified.png" 
              alt="Angi Certified" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/licensed-insured.png" 
              alt="Licensed & Insured" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/bbb-logo.png" 
              alt="BBB Accredited Business" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/google-reviews.webp" 
              alt="Google Reviews" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/certified.png" 
              alt="Certified Professional" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <!-- Duplicate Set for Seamless Loop -->
          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/24-7-service.png" 
              alt="24/7 Service Available" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/angi-certified.png" 
              alt="Angi Certified" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/licensed-insured.png" 
              alt="Licensed & Insured" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/bbb-logo.png" 
              alt="BBB Accredited Business" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/google-reviews.webp" 
              alt="Google Reviews" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>

          <div class="flex items-center justify-center opacity-70 flex-shrink-0">
            <img 
              src="/certified.png" 
              alt="Certified Professional" 
              class="h-16 w-auto object-contain"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-scroll {
    animation: scroll 20s linear infinite;
  }

  /* Pause animation on hover */
  .trust-badges-track:hover {
    animation-play-state: paused;
  }
</style>
